        {"candidate_id": "aga_three_strain_cdi_prevention", "strains": ["Lactobacillus acidophilus", "Lactobacillus delbrueckii subsp. bulgaricus", "Bifidobacterium bifidum"]},
        {"candidate_id": "aga_four_strain_cdi_prevention", "strains": ["Lactobacillus acidophilus", "Lactobacillus delbrueckii subsp. bulgaricus", "Bifidobacterium bifidum", "Streptococcus salivarius subsp. thermophilus"]}
      ]
    },
    {
