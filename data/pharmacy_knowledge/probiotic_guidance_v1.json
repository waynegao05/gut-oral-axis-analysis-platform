      "condition_codes": ["pouchitis"],
      "requires_recent_antibiotics": false,
      "stance": "conditional_guideline_option",
      "evidence_scope_zh": "仅限经临床确认的储袋炎管理情境；产品必须核对到具体菌株组合，不能用任意多菌产品替代。",
      "candidates": [
