      "requires_recent_antibiotics": true,
      "stance": "conditional_guideline_options",
      "evidence_scope_zh": "仅限正在接受抗生素治疗时预防艰难梭菌感染的指南情境，不适用于治疗已发生的感染，也不由菌群丰度单独触发。",
      "candidates": [
